# ============================================================
# RemplApp — Variables d'environnement
# Copiez ce fichier en .env.local et remplissez les valeurs.
# ============================================================

# Supabase — obtenir sur https://supabase.com > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://VOTRE_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=votre_anon_key_ici

# Service Role Key — uniquement côté serveur (suppression de compte RGPD)
# NE PAS préfixer en NEXT_PUBLIC_ — ne jamais exposer côté client
# Obtenir sur : Project Settings > API > service_role
SUPABASE_SERVICE_ROLE_KEY=votre_service_role_key_ici
